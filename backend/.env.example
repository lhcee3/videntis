# Render deployment — set this in Render's environment variables dashboard
# PYTHON_VERSION=3.11.9

ENABLE_CACHE=true
CACHE_TTL_PRICE=60
CACHE_TTL_TECHNICAL=300
CACHE_TTL_FUNDAMENTALS=86400
CACHE_TTL_FORECAST=3600

ENABLE_FALLBACK_SOURCES=true
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

ENABLE_SEC_EDGAR=true
SEC_EMAIL=your.email@example.com

ENABLE_AKSHARE=true
ENABLE_WEBSOCKET=true

RATE_LIMIT_FINNHUB=55
RATE_LIMIT_ALPHA_VANTAGE=24
