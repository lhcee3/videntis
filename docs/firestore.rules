rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User document — only the authenticated owner can read or write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Portfolio holdings — scoped to the owning user
      match /portfolio/{ticker} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Watchlist — scoped to the owning user
      match /watchlist/{ticker} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Cached predictions — any authenticated user can read, no client writes
    match /predictions/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
